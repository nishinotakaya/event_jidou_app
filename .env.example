# ===== 各サイトのログイン情報 =====
# このファイルをコピーして .env にリネームし、実際の値を入力してください
# cp .env.example .env

# こくチーズ
KOKUCH_EMAIL=your-email@example.com
KOKUCH_PASSWORD=your-password

# Peatix
PEATIX_EMAIL=your-email@example.com
PEATIX_PASSWORD=your-password

# connpass
CONNPASS_EMAIL=your-email@example.com
CONNPASS_PASSWORD=your-password

# techplay
TECHPLAY_EMAIL=your-email@example.com
TECHPLAY_PASSWORD=your-password

# e-running（受講生サポート）
ERUNNING_URL=https://your-erunning-url.com
ERUNNING_EMAIL=your-email@example.com
ERUNNING_PASSWORD=your-password
